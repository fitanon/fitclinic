// ============== SESSION PROCESSING ==============\
function processNewLogs() \{\
  const startTime = new Date();\
  const ss = SpreadsheetApp.getActiveSpreadsheet();\
  const logsSheet = ss.getSheetByName(TABS.SESSION_LOGS);\
  const mappingsSheet = ss.getSheetByName(TABS.MAPPINGS);\
  \
  const lastRow = logsSheet.getLastRow();\
  if (lastRow < 2) return;\
  \
  const logsData = logsSheet.getRange(2, 1, lastRow - 1, 15).getValues();\
  const mappings = getMappings(mappingsSheet);\
  const salesIndex = buildSalesIndex(ss);\
  \
  let processed = 0, matched = 0, unmatched = 0;\
  const updates = [];\
  \
  logsData.forEach((row, index) => \{\
    const rowNum = index + 2;\
    const isProcessed = row[10];\
    \
    if (isProcessed !== true && isProcessed !== 'TRUE') \{\
      const status = row[6];\
      const clientId = row[2];\
      const customerId = row[3];\
      const trainer = row[4];\
      const title = row[5] || '';\
      const keywords = row[9] || '';\
      const isTandem = row[13];\
      \
      let deductQty = 0;\
      let matchedSaleId = '';\
      \
      if (status === 'Completed' || status === 'completed') \{\
        deductQty = inferDeductQuantity(title + ' ' + keywords, mappings);\
        \
        if (!clientId && customerId) \{\
          const consolidatedId = consolidateCustomerID(customerId);\
          const clientInfo = findClientByCustomerID(consolidatedId);\
          if (clientInfo) \{\
            logsSheet.getRange(rowNum, 3).setValue(clientInfo.clientId);\
          \}\
        \}\
        matched++;\
      \} else if (status === 'No-Show' || status === 'no-show') \{\
        deductQty = 0.5;\
        matched++;\
      \}\
      \
      if ((clientId || customerId) && deductQty > 0) \{\
        matchedSaleId = salesIndex[clientId || customerId] || '';\
        if (!matchedSaleId) \{\
          logDiscrepancy(ss, row[0], clientId, customerId, row[1], 'No active sale found');\
          unmatched++;\
        \}\
      \}\
      \
      if (status === 'Completed' && trainer && deductQty > 0) \{\
        createPayrollEntry(ss, row[0], trainer, row[1], title, isTandem);\
      \}\
      \
      updates.push(\{\
        row: rowNum,\
        processed: true,\
        deductQty: deductQty,\
        matchedSaleId: matchedSaleId\
      \});\
      \
      processed++;\
    \}\
  \});\
  \
  if (updates.length > 0) \{\
    updates.forEach(update => \{\
      logsSheet.getRange(update.row, 11).setValue(update.processed);\
      logsSheet.getRange(update.row, 12).setValue(update.deductQty);\
      logsSheet.getRange(update.row, 13).setValue(update.matchedSaleId);\
    \});\
  \}\
