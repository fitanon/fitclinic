// ============== FORMULA SETUP ==============\
function setupFormulas(ss) \{\
  const counterSheet = ss.getSheetByName(TABS.SESSION_COUNTER);\
  const lastRow = Math.max(100, counterSheet.getLastRow());\
  \
  const purchasedFormula = `=IFERROR(SUMIFS('$\{TABS.SALES\}'!E:E, '$\{TABS.SALES\}'!B:B, A2), 0)`;\
  counterSheet.getRange(`D2:D$\{lastRow\}`).setFormula(purchasedFormula);\
  \
  const usedFormula = `=IFERROR(SUMIFS('$\{TABS.SESSION_LOGS\}'!L:L, '$\{TABS.SESSION_LOGS\}'!C:C, A2, '$\{TABS.SESSION_LOGS\}'!K:K, TRUE), 0)`;\
  counterSheet.getRange(`E2:E$\{lastRow\}`).setFormula(usedFormula);\
  \
  const adjNetFormula = `=IFERROR(SUMIFS('$\{TABS.ADJUSTMENTS\}'!E:E, '$\{TABS.ADJUSTMENTS\}'!B:B, A2, '$\{TABS.ADJUSTMENTS\}'!D:D, "credit") - SUMIFS('$\{TABS.ADJUSTMENTS\}'!E:E, '$\{TABS.ADJUSTMENTS\}'!B:B, A2, '$\{TABS.ADJUSTMENTS\}'!D:D, "debit"), 0)`;\
  counterSheet.getRange(`F2:F$\{lastRow\}`).setFormula(adjNetFormula);\
  \
  const leftFormula = '=MAX(D2 + F2 - E2, 0)';\
  counterSheet.getRange(`G2:G$\{lastRow\}`).setFormula(leftFormula);\
  \
  const tandemCreditsFormula = `=IFERROR(SUMIFS('$\{TABS.ADJUSTMENTS\}'!F:F, '$\{TABS.ADJUSTMENTS\}'!B:B, A2, '$\{TABS.ADJUSTMENTS\}'!G:G, "Tandem Credit"), 0)`;\
  counterSheet.getRange(`H2:H$\{lastRow\}`).setFormula(tandemCreditsFormula);\
  \
  setupGoogleSitesViews(ss);\
\}\
