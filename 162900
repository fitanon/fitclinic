// ============== SQUARE API INTEGRATION ==============\
function fetchFromSquare(startDate, endDate) \{\
  const startTime = new Date();\
  const ss = SpreadsheetApp.getActiveSpreadsheet();\
  \
  try \{\
    const props = PropertiesService.getScriptProperties();\
    const appointmentsToken = props.getProperty('APPOINTMENTS_TOKEN');\
    const salesToken = props.getProperty('SALES_TOKEN');\
    const unifiedToken = props.getProperty('UNIFIED_TOKEN');\
    \
    let totalProcessed = 0;\
    let totalMatched = 0;\
    let totalUnmatched = 0;\
    \
    const appointmentsCutoff = CONFIG.ACCOUNTS.APPOINTMENTS_OLD.cutoffDate;\
    const unifiedStart = CONFIG.ACCOUNTS.UNIFIED_NEW.startDate;\
    \
    if (startDate < appointmentsCutoff && appointmentsToken) \{\
      const result = fetchBookings(appointmentsToken, 'APPOINTMENTS_OLD', \
                                  startDate, Math.min(endDate, appointmentsCutoff));\
      totalProcessed += result.processed;\
      totalMatched += result.matched;\
      totalUnmatched += result.unmatched;\
    \}\
    \
    if (endDate >= unifiedStart && unifiedToken) \{\
      const result = fetchBookings(unifiedToken, 'UNIFIED_NEW',\
                                  Math.max(startDate, unifiedStart), endDate);\
      totalProcessed += result.processed;\
      totalMatched += result.matched;\
      totalUnmatched += result.unmatched;\
    \}\
    \
    if (salesToken) \{\
      const salesResult = fetchOrders(salesToken, 'SALES', startDate, endDate);\
      totalProcessed += salesResult.processed;\
    \}\
    \
    processNewLogs();\
    \
    const duration = new Date() - startTime;\
    logETL(ss, 'SQUARE_SYNC', totalProcessed, totalMatched, totalUnmatched, 0, duration, \
           `Synced from $\{startDate.toISOString()\} to $\{endDate.toISOString()\}`);\
    \
    return \{\
      success: true,\
      processed: totalProcessed,\
      matched: totalMatched,\
      unmatched: totalUnmatched\
    \};\
    \
  \} catch (error) \{\
    console.error('Square sync error:', error);\
    const duration = new Date() - startTime;\
    logETL(ss, 'SQUARE_SYNC_ERROR', 0, 0, 0, 1, duration, error.toString());\
    throw error;\
  \}\
\}\
\
function fetchBookings(token, source, startDate, endDate) \{\
  const ss = SpreadsheetApp.getActiveSpreadsheet();\
  const logsSheet = ss.getSheetByName(TABS.SESSION_LOGS);\
  const props = PropertiesService.getScriptProperties();\
  const locationId = props.getProperty(source === 'APPOINTMENTS_OLD' ? 'APPOINTMENTS_LOCATION' : \
                                       source === 'SALES' ? 'SALES_LOCATION' : 'UNIFIED_LOCATION');\
  \
  let cursor = null;\
  let processed = 0;\
  let matched = 0;\
  let unmatched = 0;\
  \
  do \{\
    const url = `$\{CONFIG.API_BASE_URL\}/bookings`;\
    const params = \{\
      'limit': CONFIG.BATCH_SIZE,\
      'location_id': locationId,\
      'start_at_min': startDate.toISOString(),\
      'start_at_max': endDate.toISOString()\
    \};\
    \
    if (cursor) \{\
      params.cursor = cursor;\
    \}\
    \
    const options = \{\
      'method': 'get',\
      'headers': \{\
        'Authorization': `Bearer $\{token\}`,\
        'Content-Type': 'application/json',\
        'Square-Version': '2024-01-18'\
      \},\
      'muteHttpExceptions': true\
    \};\
    \
    const queryString = Object.keys(params)\
      .map(key => `$\{key\}=$\{encodeURIComponent(params[key])\}`)\
      .join('&');\
    \
    const response = UrlFetchApp.fetch(`$\{url\}?$\{queryString\}`, options);\
    const result = JSON.parse(response.getContentText());\
    \
    if (result.bookings) \{\
      result.bookings.forEach(booking => \{\
        const logId = `$\{source\}-$\{booking.id\}`;\
        \
        if (!isDuplicateLog(logsSheet, logId)) \{\
          const originalCustomerId = booking.customer_id || '';\
          const consolidatedCustomerId = consolidateCustomerID(originalCustomerId);\
          const clientInfo = findClientByCustomerID(consolidatedCustomerId);\
          \
          logsSheet.appendRow([\
            logId,\
            new Date(booking.start_at),\
            clientInfo ? clientInfo.clientId : '',\
            originalCustomerId,\
            booking.team_member_id || '',\
            booking.service_variation_name || booking.appointment_segments?.[0]?.service_variation_name || '',\
            booking.status || 'ACCEPTED',\
            booking.location_id || '',\
            booking.duration_minutes || '',\
            '',\
            false,\
            '',\
            '',\
            false,\
            ''\
          ]);\
          \
          processed++;\
          if (originalCustomerId) \{\
            matched++;\
          \} else \{\
            unmatched++;\
          \}\
        \}\
      \});\
    \}\
    \
    cursor = result.cursor;\
  \} while (cursor);\
  \
  return \{ processed, matched, unmatched \};\
\}\
\
function fetchOrders(token, source, startDate, endDate) \{\
  const ss = SpreadsheetApp.getActiveSpreadsheet();\
  const salesSheet = ss.getSheetByName(TABS.SALES);\
  const props = PropertiesService.getScriptProperties();\
  const locationId = props.getProperty('SALES_LOCATION');\
  \
  let processed = 0;\
  const url = `$\{CONFIG.API_BASE_URL\}/orders/search`;\
  \
  const body = \{\
    'location_ids': [locationId],\
    'filter': \{\
      'date_time_filter': \{\
        'created_at': \{\
          'start_at': startDate.toISOString(),\
          'end_at': endDate.toISOString()\
        \}\
      \}\
    \},\
    'limit': CONFIG.BATCH_SIZE\
  \};\
  \
  const options = \{\
    'method': 'post',\
    'headers': \{\
      'Authorization': `Bearer $\{token\}`,\
      'Content-Type': 'application/json',\
      'Square-Version': '2024-01-18'\
    \},\
    'payload': JSON.stringify(body),\
    'muteHttpExceptions': true\
  \};\
  \
  const response = UrlFetchApp.fetch(url, options);\
  const result = JSON.parse(response.getContentText());\
  \
  if (result.orders) \{\
    result.orders.forEach(order => \{\
      const lineItems = order.line_items || [];\
      lineItems.forEach(item => \{\
        if (item.name && (item.name.includes('Session') || item.name.includes('Pack'))) \{\
          const originalCustomerId = order.customer_id || '';\
          const consolidatedCustomerId = consolidateCustomerID(originalCustomerId);\
          const clientInfo = findClientByCustomerID(consolidatedCustomerId);\
          \
          const sessionMatch = item.name.match(/(\\d+)[\\s-]*(Pack|Session)/i);\
          const sessionCount = sessionMatch ? parseInt(sessionMatch[1]) : 1;\
          \
          salesSheet.appendRow([\
            `$\{source\}-$\{order.id\}-$\{item.uid\}`,\
            clientInfo ? clientInfo.clientId : '',\
            originalCustomerId,\
            item.name,\
            sessionCount,\
            new Date(order.created_at),\
            new Date(order.created_at),\
            parseFloat(item.base_price_money?.amount || 0) / 100,\
            '',\
            source,\
            order.note || ''\
          ]);\
          \
          processed++;\
        \}\
      \});\
    \});\
  \}\
  \
  return \{ processed \};\
\}\
\
function isDuplicateLog(logsSheet, logId) \{\
  const lastRow = logsSheet.getLastRow();\
  if (lastRow < 2) return false;\
  \
  const logIds = logsSheet.getRange(2, 1, lastRow - 1, 1).getValues().flat();\
  return logIds.includes(logId);\
\}\
