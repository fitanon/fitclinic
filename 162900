function generateImportReport() \{\
  const ss = SpreadsheetApp.getActiveSpreadsheet();\
  const ui = SpreadsheetApp.getUi();\
  \
  const report = [];\
  \
  const logsSheet = ss.getSheetByName('Session Logs');\
  const logsData = logsSheet.getRange(2, 1, Math.max(1, logsSheet.getLastRow() - 1), 1).getValues().flat();\
  \
  const sources = \{\
    'FORM': 0,\
    'CAL': 0,\
    'SQUARE': 0,\
    'APPOINTMENTS_OLD': 0,\
    'UNIFIED_NEW': 0,\
    'SALES': 0,\
    'CUSTOM': 0,\
    'LOG': 0,\
    'Other': 0\
  \};\
  \
  logsData.forEach(logId => \{\
    const prefix = logId.split('-')[0];\
    if (sources[prefix] !== undefined) \{\
      sources[prefix]++;\
    \} else \{\
      sources['Other']++;\
    \}\
  \});\
  \
  report.push('\uc0\u55357 \u56522  IMPORT REPORT\\n');\
  report.push('Session Logs by Source:');\
  Object.entries(sources).forEach(([source, count]) => \{\
    if (count > 0) \{\
      report.push(`  $\{source\}: $\{count\} records`);\
    \}\
  \});\
  \
  const clientsSheet = ss.getSheetByName('Clients');\
  const salesSheet = ss.getSheetByName('Sales');\
  const mapSheet = ss.getSheetByName('CustomerIDMap');\
  \
  report.push('\\nData Quality:');\
  report.push(`  Total Clients: $\{Math.max(0, clientsSheet.getLastRow() - 1)\}`);\
  report.push(`  Total Sales: $\{Math.max(0, salesSheet.getLastRow() - 1)\}`);\
  report.push(`  Customer ID Mappings: $\{Math.max(0, mapSheet.getLastRow() - 1)\}`);\
  \
  const discSheet = ss.getSheetByName('Discrepancies');\
  const unresolved = Math.max(0, discSheet.getLastRow() - 1);\
  \
  if (unresolved > 0) \{\
    report.push(`\\n\uc0\u9888 \u65039  Unresolved Issues: $\{unresolved\}`);\
    report.push('Run "Validate & Fix Data" to resolve');\
  \} else \{\
    report.push('\\n\uc0\u9989  No unresolved issues');\
  \}\
  \
  ui.alert('Import Report', report.join('\\n'), ui.ButtonSet.OK);\
\}\
