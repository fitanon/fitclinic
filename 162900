function processFormResponses(data) \{\
  const ss = SpreadsheetApp.getActiveSpreadsheet();\
  const logsSheet = ss.getSheetByName('Session Logs');\
  const payrollSheet = ss.getSheetByName('Payroll');\
  \
  const headers = data[0];\
  const columnMap = \{\};\
  headers.forEach((header, index) => \{\
    columnMap[header.toLowerCase()] = index;\
  \});\
  \
  for (let i = 1; i < data.length; i++) \{\
    const row = data[i];\
    \
    const timestamp = row[columnMap['timestamp']] || new Date();\
    const clientName = row[columnMap['client name']] || row[columnMap['name']] || '';\
    const trainer = row[columnMap['trainer']] || row[columnMap['staff']] || '';\
    const sessionType = row[columnMap['session type']] || row[columnMap['type']] || '';\
