// ============== CUSTOMER ID CONSOLIDATION ==============\
function consolidateCustomerID(customerID) \{\
  const ss = SpreadsheetApp.getActiveSpreadsheet();\
  const mapSheet = ss.getSheetByName(TABS.CUSTOMER_ID_MAP);\
  \
  if (!mapSheet || mapSheet.getLastRow() < 2) \{\
    return customerID;\
  \}\
  \
  const mappings = mapSheet.getRange(2, 1, mapSheet.getLastRow() - 1, 7).getValues();\
  \
  for (const mapping of mappings) \{\
    if (mapping[0] === customerID && mapping[6] === true) \{\
      return mapping[1];\
    \}\
  \}\
  \
  for (const mapping of mappings) \{\
    if (mapping[1] === customerID) \{\
      return customerID;\
    \}\
  \}\
  \
  return customerID;\
\}\
\
function findClientByCustomerID(customerID) \{\
  const ss = SpreadsheetApp.getActiveSpreadsheet();\
  const clientsSheet = ss.getSheetByName(TABS.CLIENTS);\
  \
  if (clientsSheet.getLastRow() < 2) return null;\
  \
  const clientsData = clientsSheet.getRange(2, 1, clientsSheet.getLastRow() - 1, 8).getValues();\
  \
  for (const client of clientsData) \{\
    if (client[6] === customerID) \{\
      return \{\
        clientId: client[0],\
        name: `$\{client[1]\} $\{client[2]\}`.trim(),\
        email: client[3]\
      \};\
    \}\
  \}\
  \
  for (const client of clientsData) \{\
    const allIDs = client[7] ? client[7].split(',').map(id => id.trim()) : [];\
    if (allIDs.includes(customerID)) \{\
      return \{\
        clientId: client[0],\
        name: `$\{client[1]\} $\{client[2]\}`.trim(),\
        email: client[3]\
      \};\
    \}\
  \}\
  \
  return null;\
\}\
