function processSalesImport(csvData) \{\
  const ss = SpreadsheetApp.getActiveSpreadsheet();\
  const salesSheet = ss.getSheetByName('Sales');\
  const clientsSheet = ss.getSheetByName('Clients');\
  \
  const rows = csvData.split('\\n').map(row => \{\
    const matches = row.match(/(".*?"|[^",\\s]+)(?=\\s*,|\\s*$)/g);\
    return matches ? matches.map(m => m.replace(/^"(.*)"$/, '$1').trim()) : [];\
  \});\
  \
  const hasHeader = rows[0][0] && rows[0][0].toLowerCase().includes('date');\
  const dataRows = hasHeader ? rows.slice(1) : rows;\
  \
  let imported = 0;\
  \
  dataRows.forEach((row, index) => \{\
    if (row.length < 7) return;\
    \
    const dateInvoiced = new Date(row[0]);\
    const datePaid = row[1] ? new Date(row[1]) : dateInvoiced;\
    const clientName = row[2];\
    const amountPaid = parseFloat(row[5]) || 0;\
    const invoiceNumber = row[6];\
    const customerID = row[7] || '';\
    \
    let packageName = 'Sessions';\
    let sessionCount = 1;\
    \
    if (amountPaid >= 900) \{\
      packageName = '20-Pack Sessions';\
      sessionCount = 20;\
    \} else if (amountPaid >= 450 && amountPaid < 550) \{\
      packageName = '10-Pack Sessions';\
      sessionCount = 10;\
    \} else if (amountPaid >= 200 && amountPaid < 300) \{\
      packageName = '5-Pack Sessions';\
      sessionCount = 5;\
    \} else if (amountPaid >= 1000) \{\
      packageName = 'Monthly Unlimited';\
      sessionCount = 30;\
    \}\
    \
    let clientId = findOrCreateClient(clientsSheet, clientName, customerID);\
    \
    salesSheet.appendRow([\
      invoiceNumber || 'SALE-IMPORT-' + index,\
      clientId,\
      customerID,\
      packageName,\
      sessionCount,\
      datePaid,\
      dateInvoiced,\
      amountPaid,\
      '',\
      'IMPORT',\
      `Imported from sales data`\
    ]);\
    \
    imported++;\
  \});\
  \
  updateSessionCounter(ss);\
  \
  return imported;\
\}\
\
function findOrCreateClient(clientsSheet, name, customerID) \{\
  if (customerID) \{\
    const clients = clientsSheet.getDataRange().getValues();\
    for (let i = 1; i < clients.length; i++) \{\
      if (clients[i][7] && clients[i][7].includes(customerID)) \{\
        return clients[i][0];\
      \}\
    \}\
  \}\
  \
  const nameParts = name.split(' ');\
  const firstName = nameParts[0] || '';\
  const lastName = nameParts.slice(1).join(' ') || '';\
  \
  const clients = clientsSheet.getDataRange().getValues();\
  for (let i = 1; i < clients.length; i++) \{\
    if (clients[i][1] === firstName && clients[i][2] === lastName) \{\
      if (customerID && !clients[i][7].includes(customerID)) \{\
        const allIDs = clients[i][7] ? clients[i][7] + ',' + customerID : customerID;\
        clientsSheet.getRange(i + 1, 8).setValue(allIDs);\
      \}\
      return clients[i][0];\
    \}\
  \}\
  \
  const newClientId = 'CL-' + Date.now();\
  clientsSheet.appendRow([\
    newClientId,\
    firstName,\
    lastName,\
    '',\
    '',\
    'Active',\
    customerID,\
    customerID\
  ]);\
  \
  return newClientId;\
\}\
\
function consolidateDuplicateCustomers() \{\
  const ss = SpreadsheetApp.getActiveSpreadsheet();\
  const clientsSheet = ss.getSheetByName('Clients');\
  const mapSheet = ss.getSheetByName('CustomerIDMap');\
  const ui = SpreadsheetApp.getUi();\
  \
  if (clientsSheet.getLastRow() < 2) \{\
    ui.alert('No clients to consolidate');\
    return;\
  \}\
  \
  const clients = clientsSheet.getRange(2, 1, clientsSheet.getLastRow() - 1, 8).getValues();\
  const duplicates = \{\};\
  \
  clients.forEach((client, index) => \{\
    const fullName = `$\{client[1]\} $\{client[2]\}`.trim().toLowerCase();\
    if (!duplicates[fullName]) \{\
      duplicates[fullName] = [];\
    \}\
    duplicates[fullName].push(\{\
      row: index + 2,\
      clientId: client[0],\
      customerIds: client[7] ? client[7].split(',') : [],\
      email: client[3]\
    \});\
  \});\
  \
  let consolidationCount = 0;\
  \
  Object.entries(duplicates).forEach(([name, entries]) => \{\
    if (entries.length > 1) \{\
      entries.sort((a, b) => \{\
        if (a.email && !b.email) return -1;\
        if (!a.email && b.email) return 1;\
        return b.customerIds.length - a.customerIds.length;\
      \});\
      \
      const primary = entries[0];\
      const allCustomerIds = new Set();\
      \
      entries.forEach(entry => \{\
        entry.customerIds.forEach(id => allCustomerIds.add(id));\
      \});\
      \
      clientsSheet.getRange(primary.row, 8).setValue(Array.from(allCustomerIds).join(','));\
      \
      entries.slice(1).forEach(entry => \{\
        entry.customerIds.forEach(oldId => \{\
          if (oldId && oldId !== primary.customerIds[0]) \{\
            mapSheet.appendRow([\
              oldId,\
              primary.customerIds[0] || primary.clientId,\
              name,\
              primary.email || '',\
              'Auto-consolidation',\
              new Date(),\
              true\
            ]);\
          \}\
        \});\
        \
        clientsSheet.getRange(entry.row, 6).setValue('Duplicate');\
      \});\
      \
      consolidationCount++;\
    \}\
  \});\
  \
  ui.alert(`Consolidation Complete`, \
    `Found and consolidated $\{consolidationCount\} duplicate client records`, \
    ui.ButtonSet.OK);\
\}\
\
function validateAndFixData() \{\
  const ss = SpreadsheetApp.getActiveSpreadsheet();\
  const ui = SpreadsheetApp.getUi();\
  const fixes = [];\
  \
  const logsSheet = ss.getSheetByName('Session Logs');\
  const logsData = logsSheet.getRange(2, 1, Math.max(1, logsSheet.getLastRow() - 1), 15).getValues();\
  \
  let unmatchedFixed = 0;\
  logsData.forEach((log, index) => \{\
    if (!log[2] && log[3]) \{\
      const consolidatedId = consolidateCustomerID(log[3]);\
      const clientInfo = findClientByCustomerID(consolidatedId);\
      if (clientInfo) \{\
        logsSheet.getRange(index + 2, 3).setValue(clientInfo.clientId);\
        unmatchedFixed++;\
      \}\
    \}\
  \});\
  \
  if (unmatchedFixed > 0) \{\
    fixes.push(`\uc0\u10003  Matched $\{unmatchedFixed\} session logs to clients`);\
  \}\
  \
  const unprocessed = logsData.filter(log => log[10] !== true && log[10] !== 'TRUE');\
  if (unprocessed.length > 0) \{\
    processNewLogs();\
    fixes.push(`\uc0\u10003  Processed $\{unprocessed.length\} pending session logs`);\
  \}\
  \
  updateSessionCounter(ss);\
  fixes.push(`\uc0\u10003  Rebuilt session counter`);\
  \
  const tandemLogs = logsData.filter(log => log[13] === true);\
  const adjSheet = ss.getSheetByName('Adjustments');\
  const adjData = adjSheet.getDataRange().getValues();\
  \
  let missingCredits = 0;\
  tandemLogs.forEach(log => \{\
    const hasCredit = adjData.some(adj => adj[8] === log[0]);\
    if (!hasCredit && log[2]) \{\
      handleTandemSession(log[0], log[2], log[14]);\
      missingCredits++;\
    \}\
  \});\
  \
  if (missingCredits > 0) \{\
    fixes.push(`\uc0\u10003  Added $\{missingCredits\} missing tandem credits`);\
  \}\
  \
  const message = fixes.length > 0 \
    ? 'Data Validation Complete:\\n\\n' + fixes.join('\\n')\
    : 'No issues found - data is valid!';\
  \
  ui.alert('Data Validation', message, ui.ButtonSet.OK);\
\}\
