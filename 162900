  const logsSheet = ss.getSheetByName('Session Logs');\
  \
  const rows = data.split('\\n').map(row => row.split(/[,\\t]/).map(cell => cell.trim()));\
  let imported = 0;\
  \
  rows.forEach((row, index) => \{\
    if (row.length < 3) return;\
    \
    let logEntry = [];\
    \
    if (sourceType === 'calendar') \{\
      logEntry = [\
        'CAL-IMPORT-' + index,\
        new Date(row[0]),\
        '',\
        '',\
        row[4] || 'Unknown',\
        row[1],\
        'Completed',\
        row[5] || 'Main Gym',\
        parseInt(row[2]) || 60,\
        row[1].toLowerCase(),\
        false,\
        '',\
        '',\
        row[1].toLowerCase().includes('tandem'),\
        ''\
      ];\
    \} else if (sourceType === 'square') \{\
      logEntry = [\
        'SQ-IMPORT-' + row[0],\
        new Date(row[1]),\
        '',\
        row[2],\
        '',\
        row[3],\
        row[5] || 'Completed',\
        'Main Gym',\
        parseInt(row[4]) || 60,\
        row[3].toLowerCase(),\
        false,\
        '',\
        '',\
        row[3].toLowerCase().includes('tandem'),\
        ''\
      ];\
    \} else \{\
      logEntry = [\
        'CUSTOM-IMPORT-' + index,\
        new Date(row[0]),\
        '',\
        '',\
        row[3] || '',\
        row[2],\
        'Completed',\
        'Main Gym',\
        60,\
        row[2].toLowerCase(),\
        false,\
        '',\
        '',\
        row[2].toLowerCase().includes('tandem'),\
        ''\
      ];\
    \}\
    \
    logsSheet.appendRow(logEntry);\
    imported++;\
  \});\
  \
  processNewLogs();\
  \
  return imported;\
\}\
