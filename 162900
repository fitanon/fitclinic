function inferDeductQuantity(text, mappings) \{\
  const lowerText = text.toLowerCase();\
  \
  for (const mapping of mappings) \{\
    if (mapping.keyword && lowerText.includes(mapping.keyword.toLowerCase())) \{\
      return parseFloat(mapping.deductQty) || 0;\
    \}\
  \}\
  \
  return 1;\
\}\
\
function getMappings(mappingsSheet) \{\
  const lastRow = mappingsSheet.getLastRow();\
  if (lastRow < 2) return [];\
  \
  const data = mappingsSheet.getRange(2, 1, lastRow - 1, 5).getValues();\
  return data.map(row => (\{\
    keyword: row[0],\
    deductQty: row[1],\
    sessionType: row[2],\
    trainerRate: row[3],\
    packageFilter: row[4]\
  \}));\
\}\
\
function buildSalesIndex(ss) \{\
  const salesSheet = ss.getSheetByName(TABS.SALES);\
  const lastRow = salesSheet.getLastRow();\
  if (lastRow < 2) return \{\};\
  \
  const salesData = salesSheet.getRange(2, 1, lastRow - 1, 11).getValues();\
  const index = \{\};\
  \
  salesData.sort((a, b) => \{\
    const dateA = new Date(a[6] || a[5]);\
    const dateB = new Date(b[6] || b[5]);\
    return dateB - dateA;\
  \});\
  \
  salesData.forEach(row => \{\
    const saleId = row[0];\
    const clientId = row[1];\
    const customerId = row[2];\
    \
    if (clientId && !index[clientId]) \{\
      index[clientId] = saleId;\
    \}\
    if (customerId && !index[customerId]) \{\
      index[customerId] = saleId;\
    \}\
  \});\
  \
  return index;\
\}\
\
function updateSessionCounter(ss) \{\
  const counterSheet = ss.getSheetByName(TABS.SESSION_COUNTER);\
  const clientsSheet = ss.getSheetByName(TABS.CLIENTS);\
  const salesSheet = ss.getSheetByName(TABS.SALES);\
  \
  const clientsData = clientsSheet.getRange(2, 1, Math.max(1, clientsSheet.getLastRow() - 1), 3).getValues();\
  const counterData = [];\
  \
  clientsData.forEach(client => \{\
    const clientId = client[0];\
    if (clientId) \{\
      const latestSale = getLatestSaleForClient(salesSheet, clientId);\
      const name = `$\{client[1]\} $\{client[2]\}`.trim();\
      \
      counterData.push([\
        clientId,\
        name,\
        latestSale.packageName || '',\
        '',\
        '',\
        '',\
        '',\
        '',\
        latestSale.startDate || ''\
      ]);\
    \}\
  \});\
  \
  if (counterData.length > 0) \{\
    if (counterSheet.getLastRow() > 1) \{\
      counterSheet.getRange(2, 1, counterSheet.getLastRow() - 1, 9).clearContent();\
    \}\
    counterSheet.getRange(2, 1, counterData.length, 9).setValues(counterData);\
    setupFormulas(ss);\
  \}\
\}\
