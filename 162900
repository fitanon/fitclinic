// ============== PAYROLL MANAGEMENT ==============\
function createPayrollEntry(ss, sessionId, trainer, date, sessionType, isTandem) \{\
  const payrollSheet = ss.getSheetByName(TABS.PAYROLL);\
  const staffSheet = ss.getSheetByName(TABS.STAFF);\
  \
  let baseRate = 50;\
  if (staffSheet.getLastRow() > 1) \{\
    const staffData = staffSheet.getRange(2, 1, staffSheet.getLastRow() - 1, 5).getValues();\
    const trainerInfo = staffData.find(row => row[1] === trainer);\
    if (trainerInfo && trainerInfo[4]) \{\
      baseRate = trainerInfo[4];\
    \}\
  \}\
  \
  const tandemBonus = isTandem ? CONFIG.TANDEM.TRAINER_BONUS : 0;\
  const totalPay = baseRate + tandemBonus;\
  \
  payrollSheet.appendRow([\
    'PAY-' + Date.now(),\
    trainer,\
    sessionId,\
    date,\
    sessionType,\
    baseRate,\
    tandemBonus,\
    totalPay,\
    'Pending',\
    ''\
  ]);\
\}\
