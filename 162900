function createOrUpdateSheet(ss, sheetName, headers) \{\
  let sheet = ss.getSheetByName(sheetName);\
  if (!sheet) \{\
    sheet = ss.insertSheet(sheetName);\
  \}\
  \
  if (sheet.getLastRow() === 0) \{\
    sheet.getRange(1, 1, 1, headers[0].length).setValues(headers);\
    sheet.getRange(1, 1, 1, headers[0].length).setFontWeight('bold');\
    \
    if (sheetName === TABS.SESSION_LOGS) \{\
      const statusRule = SpreadsheetApp.newDataValidation()\
        .requireValueInList(['Completed', 'Cancelled', 'No-Show', 'Pending'])\
        .build();\
      sheet.getRange('G2:G').setDataValidation(statusRule);\
    \}\
  \}\
  \
  return sheet;\
\}\
